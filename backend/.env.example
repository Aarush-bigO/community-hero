# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Database
DB_PATH=./data/community-hero.db

# LLM provider: openai | groq | ollama | mock
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10

# Real-time City Pulse passive-listening simulator
PULSE_LIVE=true
PULSE_INTERVAL_MS=12000
